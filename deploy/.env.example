# Docker Compose Environment Variables for Toolrent Production Deployment
# Copy this file to .env and fill in the values

# Docker Hub Configuration
# Replace 'yourdockerhubusername' with your actual Docker Hub username
# The images must be available on Docker Hub: yourdockerhubusername/toolrent-app:latest and yourdockerhubusername/toolrent-front:latest
DOCKER_USERNAME=yourdockerhubusername

# Database Configuration
DB_USER=toolrent
DB_PASSWORD=your_secure_password_here
DB_DRIVER=com.mysql.cj.jdbc.Driver

# Spring Application Configuration
SPRING_APPLICATION_NAME=demo

# Network Configuration
# If you're using a different IP address or domain, update these values:
# - Replace 192.168.122.17 with your server's IP or domain
# - Update the SSL certificates in deploy/nginx/certs/ accordingly
# SERVER_IP=192.168.122.17
# DOMAIN_NAME=yourdomain.com